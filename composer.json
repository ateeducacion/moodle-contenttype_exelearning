{
    "name": "moodle/contenttype-exelearning",
    "type": "moodle-plugin",
    "description": "Moodle content bank content type to upload, store and render eXeLearning packages (.elpx and .zip).",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Area de Tecnologia Educativa",
            "email": "ate.educacion@gobiernodecanarias.org"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "moodlehq/moodle-cs": "^3.4",
        "phpmd/phpmd": "^2.15"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs -d memory_limit=1G",
        "fix": "phpcbf -d memory_limit=1G",
        "phpmd": "phpmd classes,lib.php,version.php,db text cleancode,codesize,controversial,design,naming,unusedcode",
        "test": "phpunit"
    }
}
