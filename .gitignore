# Ignore local environment files
.env

# Ignore Moodle configuration file if copied here
config.php

# Ignore Composer dependencies
/vendor/

# Ignore PHPUnit cache
.phpunit.result.cache

# Ignore log files
*.log

# Ignore macOS files
.DS_Store

# Ignore editor swap files and other temp files
*~
*.swp
.idea/
.vscode/

# Ignore moodle-plugin-ci installs and runtime data
ci/
.ci/

# Ignore Node modules and build output
node_modules/
amd/build/

# Ignore release artifacts
*.zip
# ...but keep test fixture archives
!tests/fixtures/*.zip

# Ignore agent tooling state
.omc/
.claude/
